DATABASE_URL="file:./dev.db"

# URL pública base (opcional, solo para mostrar el texto del webhook en /panel/config)
# NEXT_PUBLIC_APP_URL="https://xxxx.ngrok-free.app"

# --- WhatsApp Cloud API (Meta) — Fase 2 ---
# Token de acceso de larga duración o temporal según tu configuración en developers.facebook.com
WHATSAPP_ACCESS_TOKEN=

# ID del número de teléfono (Phone number ID en la API de WhatsApp)
WHATSAPP_PHONE_NUMBER_ID=

# Token que vos definís para verificar el webhook (GET challenge)
WHATSAPP_VERIFY_TOKEN=

# App Secret de la aplicación Meta (recomendado: valida firma del POST webhook)
WHATSAPP_APP_SECRET=

# Opcional
WHATSAPP_API_VERSION=v21.0
WHATSAPP_DEFAULT_TEMPLATE=hello_world
WHATSAPP_DEFAULT_TEMPLATE_LANG=en_US

# Alias opcionales (si ya usabas estos nombres):
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
